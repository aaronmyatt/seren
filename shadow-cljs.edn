;; shadow-cljs configuration
;; Dependencies and source paths are read from deps.edn via the :cljs alias
;;
;; Per-page module splitting: each HTML page loads only its own JS module.
;; The :shared module contains common code (cljs.core, PocketBase client, island helpers).
;; Page modules depend on :shared and contain page-specific island behavior.
;;
;; See: https://shadow-cljs.github.io/docs/UsersGuide.html#_code_splitting
{:deps {:aliases [:cljs]}

 ;; Static file server — fallback when not using Ring server
 :dev-http {8000 "public"}

 :builds
 {;; Browser build — MPA with per-page module splitting
  :browser
  {:target    :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules
   {;; Shared module — loaded on every page (PB client, island helpers)
    :shared    {:entries [seren.app.islands.shared]}
    ;; Library page island — content ingestion form + content feed
    :library   {:entries [seren.app.islands.library]
                :depends-on #{:shared}}
    ;; Dashboard page island — stats, upcoming reviews
    :dashboard {:entries [seren.app.islands.dashboard]
                :depends-on #{:shared}}
    ;; Review session island — free recall + scaffold hints
    :review    {:entries [seren.app.islands.review]
                :depends-on #{:shared}}}
   :devtools  {:after-load seren.app.islands.shared/on-reload}}

  ;; Node.js test runner — runs all *-test namespaces
  :test
  {:target    :node-test
   :output-to "out/node-tests.js"
   :ns-regexp "-test$"
   :autorun   true}}}
